# Copy this file to .env and fill in your values
# cp .env.example .env

# Full URL to your Emby server — no trailing slash
EMBY_SERVER=http://192.168.1.100:8096

# Emby API key
# Emby Dashboard → Advanced → Security → API Keys → New Key
EMBY_API_KEY=your_api_key_here

# Your Emby user ID (not your username — see README for how to find it)
EMBY_USER_ID=your_user_id_here

# Optional: override the port the app listens on (default: 3000)
# PORT=3000
